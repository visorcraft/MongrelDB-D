{
    "name": "mongreldb",
    "description": "Pure D HTTP client for MongrelDB - typed CRUD, fluent query builder, idempotent batch transactions, SQL, and schema introspection.",
    "homepage": "https://www.MongrelDB.com",
    "authors": [
        "Visorcraft"
    ],
    "copyright": "Copyright \u00a9 2026 Visorcraft",
    "license": "MIT OR Apache-2.0",
    "targetType": "library",
    "targetPath": "build",
    "dflags-dmd": [
        "-preview=dip1000"
    ],
    "buildTypes": {
        "release": {
            "buildOptions": [
                "releaseMode",
                "optimize",
                "inline"
            ]
        }
    },
    "configurations": [
        {
            "name": "library",
            "targetType": "library",
            "excludedSourceFiles": [
                "tests/*"
            ]
        },
        {
            "name": "unittest",
            "targetType": "library",
            "excludedSourceFiles": [
                "tests/*"
            ]
        },
        {
            "name": "live-test",
            "targetType": "executable",
            "mainSourceFile": "tests/main.d"
        },
        {
            "name": "wire-shape",
            "targetType": "executable",
            "mainSourceFile": "tests/test_wire_shape.d"
        }
    ],
    "version": "0.60.3"
}
